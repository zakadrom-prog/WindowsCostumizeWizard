<Window x:Class="WindowsCostumizeWizard.MW_Element.UC_Advansed.W_AddDriversImage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsCostumizeWizard.MW_Element"
        mc:Ignorable="d" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize" ShowInTaskbar="False"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource GlobalBorderBackground1}"
            BorderBrush="{DynamicResource GlobalBorderBrush0}"
            BorderThickness="1" Padding="5"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Name="TitleADI" Padding="5"
                    Background="{DynamicResource GlobalBorderBackground2}"
                    BorderBrush="{DynamicResource GlobalBorderBrush0}"
                    Width="Auto" Height="Auto" BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Source="{DynamicResource AppIcon}" Width="16"/>

                    <TextBlock Text="{DynamicResource Content_UButton5}"
                               Foreground="{DynamicResource GlobalTitleForeground0}"
                               Margin="5,0" Grid.Column="1"
                               VerticalAlignment="Center"
                               FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal" Grid.Column="2">
                        <Button Style="{DynamicResource GlobalActionButtonStyleC}"
                                Content="─" Margin="0,0,5,0"
                                BorderThickness="1"
                                Click="Minimize_Click"/>

                        <Button Style="{DynamicResource GlobalActionButtonStyleC}"
                                Content="❌" FontSize="8"
                                BorderThickness="1"
                                Click="CloseWindow_Click"/>
                    </StackPanel>

                </Grid>
            </Border>

            <Border Name="PerformADI"
                    Background="{DynamicResource GlobalBorderBackground0}"
                    BorderBrush="{DynamicResource GlobalBorderBrush0}"
                    Grid.Row="1" Width="Auto" Height="Auto"
                    Margin="0,5,0,0" Padding="5" BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource GlobalBorderBackground4}"
                            BorderBrush="{DynamicResource GlobalBorderBrush1}"
                            Padding="5" BorderThickness="1">

                        <TextBlock x:Name="TextAddressINF"
                                   Text="{Binding AddressINF}"
                                   Foreground="IndianRed"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border BorderBrush="{DynamicResource GlobalBorderBrush0}"
                            Background="{DynamicResource GlobalBorderBackground3}"
                            BorderThickness="1" Grid.Row="1"
                            Margin="0,5" Height="400" Width="820">

                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <StackPanel x:Name="PanelADIList" Orientation="Vertical"/>
                        </ScrollViewer>
                    </Border>

                    <Grid  Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnSelectFolder"
                                Style="{DynamicResource GlobalActionButtonStyle}"
                                Content="{DynamicResource Content_SelectFolderDrivers}"
                                Margin="0,0,2.5,0"
                                Click="SelectFolder_Click"/>

                        <Button x:Name="btnAddDrivers"
                                Style="{DynamicResource GlobalActionButtonStyle}"
                                Content="{DynamicResource Content_AddDrivers}"
                                Grid.Column="1"
                                IsEnabled="False" Margin="2.5,0,0,0"
                                Click="AddDrivers_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
