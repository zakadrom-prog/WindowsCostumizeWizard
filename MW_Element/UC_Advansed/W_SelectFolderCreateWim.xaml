<Window x:Class="WindowsCostumizeWizard.MW_Element.UC_Advansed.W_SelectFolderCreateWim"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsCostumizeWizard.MW_Element.UC_Advansed"
        mc:Ignorable="d" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize" ShowInTaskbar="True"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource WI_BorderBackground}"
            BorderBrush="{DynamicResource WI_BorderBrush}"
            Opacity="0.9" CornerRadius="10"
            BorderThickness="1"
            Padding="10" MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{DynamicResource Text_TitleInfoWindowInfo}"
                       Foreground="{DynamicResource GlobalTitleForeground0}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" FontWeight="Bold"/>

            <TextBlock Text="{Binding InfoText}"
                       Foreground="{DynamicResource GlobalTitleForeground1}"
                       Margin="5" VerticalAlignment="Center"
                       TextWrapping="Wrap" HorizontalAlignment="Center"
                       FontWeight="Bold" Grid.Row="1"/>

            <TextBlock Text="{DynamicResource Text_Warning}"
                       Foreground="#FF912F2F" FontSize="14"
                       Margin="0,10" VerticalAlignment="Center" Grid.Row="2"
                       TextWrapping="Wrap" HorizontalAlignment="Center"
                       FontWeight="Bold"/>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Style="{DynamicResource GlobalActionButtonStyle}"
                        Content="{DynamicResource Text_SelectFolderCreateWim}" 
                        Width="Auto" Margin="0,0,2.5,0"
                        Click="OpenFolderCreateWim_Click"/>

                <Button Style="{DynamicResource GlobalActionButtonStyle}"
                        Content="{DynamicResource Content_CloseWindow}" 
                        Width="Auto" Grid.Column="1" Margin="2.5,0,0,0"
                        Click="Ok_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
