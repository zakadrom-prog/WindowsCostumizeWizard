<UserControl x:Class="WindowsCostumizeWizard.MW_Element.UC_DeleteIndex"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:WindowsCostumizeWizard"
            mc:Ignorable="d">

    <Border Name="Global" Padding="5,0,2.5,5" Width="365">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Name="DelIndex" Padding="5"
                    Background="{DynamicResource GlobalBorderBackground2}"
                    BorderBrush="{DynamicResource GlobalBorderBrush0}"
                    Width="Auto" Height="Auto"
                    BorderThickness="1">

                <TextBlock Name="TitleName" Text="{DynamicResource Text_EditIndex}"
                           Foreground="{DynamicResource GlobalTitleForeground0}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <Border Name="ProcessorIndex"
                    Background="{DynamicResource GlobalBorderBackground0}"
                    BorderBrush="{DynamicResource GlobalBorderBrush0}"
                    Padding="5" Width="Auto" Height="Auto"
                    Grid.Row="1" BorderThickness="1" Margin="0,5,0,0">

                <StackPanel Orientation="Vertical">
                    <Border Background="{DynamicResource GlobalBorderBackground4}"
                            BorderBrush="{DynamicResource GlobalBorderBrush1}"
                            Padding="5" BorderThickness="1">

                        <TextBlock x:Name="TextStatusWim"
                                   Text="{Binding}"
                                   FontSize="10"
                                   Foreground="{DynamicResource GlobalTitleForeground2}"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Name="StatusMount"
                            Background="{DynamicResource GlobalBorderBackground3}"
                            BorderBrush="{DynamicResource GlobalBorderBrush3}"
                            Margin="0,5" Padding="3" BorderThickness="1">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="txtProgress0" Text="{DynamicResource Text_StatusOptimize0}" FontSize="10"
                                       Foreground="{DynamicResource GlobalTitleForeground3}"
                                       Margin="0,0,5,0" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />

                            <TextBlock x:Name="txtProgress1" Text="{DynamicResource Text_StatusOptimize1}" FontSize="10"
                                       Foreground="{DynamicResource GlobalTitleForeground3}"
                                       Margin="0,0,5,0" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Name="BorderIndex"
                            Background="{DynamicResource GlobalBorderBackground4}"
                            BorderBrush="{DynamicResource GlobalBorderBrush1}"
                            Padding="5" BorderThickness="1">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Name="SelectIndex">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Name="BIndex"
                                        Background="{DynamicResource GlobalBorderBackground1}"
                                        BorderBrush="{DynamicResource GlobalBorderBrush1}"
                                        BorderThickness="1,1,0,1">
                                    
                                    <TextBlock Text="{DynamicResource Text_Index}"
                                               Foreground="{DynamicResource GlobalTitleForeground1}"
                                               FontStyle="Italic" FontWeight="Medium" Margin="5,0"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <ComboBox x:Name="cbIndexWIM" Grid.Column="1"
                                          IsEnabled="False" Opacity="0.5" FontStyle="Italic"
                                          Width="Auto" Background="Black" VerticalAlignment="Center">
                                </ComboBox>

                                <Button x:Name="btnDeleteIndex" IsEnabled="False"
                                        Style="{DynamicResource GlobalActionButtonStyle}"
                                        Content="{DynamicResource Content_DeleteIndex}"
                                        Grid.Column="2" Margin="5,0,0,0"
                                        Click="DeleteIndex_Click"/>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,5,2.5,0">
                                    <Button x:Name="btnUpdateIndex" IsEnabled="False"
                                            Style="{DynamicResource GlobalActionButtonStyle}"
                                            Content="{DynamicResource Content_IndexUpdate}"
                                            Click="ReloadIndexes_Click"/>

                                    <Button x:Name="btnInfoInstall" IsEnabled="False"
                                            Style="{DynamicResource GlobalActionButtonStyle}"
                                            Content="{DynamicResource Content_InfoWim}"
                                            Margin="0,5" Click="DetailInstall_Click"/>

                                    <TextBlock x:Name="TextStatusWimlib"
                                               Foreground="{DynamicResource GlobalTitleForeground1}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="2.5,5,0,0">
                                    <Button x:Name="btnConvertImage" IsEnabled="False"
                                            Style="{DynamicResource GlobalActionButtonStyle}"
                                            Content="{DynamicResource Content_ConvertWIM}" Grid.Row="1"
                                            Click="OpenConvert_Click"/>

                                    <Button x:Name="btnOptimizeImage" IsEnabled="False"
                                            Style="{DynamicResource GlobalActionButtonStyle}"
                                            Content="{DynamicResource Content_Opz}" Margin="0,5"
                                            Click="OptimizeWim_Click"/>

                                    <Button Style="{DynamicResource GlobalActionButtonStyle}"
                                            Content="ℹ wimlib"
                                            Click="AllInfoWL_Click"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
