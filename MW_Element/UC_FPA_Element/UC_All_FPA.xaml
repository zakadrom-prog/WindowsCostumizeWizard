<UserControl x:Class="WindowsCostumizeWizard.MW_Element.UC_FPA_Element.UC_All_FPA"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsCostumizeWizard.MW_Element.UC_FPA_Element"
        mc:Ignorable="d">

    <Grid Grid.Column="2" Margin="2.5,0,5,5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Name="BorderWIMImage" Padding="0,5,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnLocalSystem"
                            Style="{DynamicResource GlobalActionButtonStyle}"
                            Content="{DynamicResource Content_MWButton0}"
                            Click="Online_Click" BorderThickness="1,1,0,0"/>

                    <Button x:Name="btnImageWim"
                            Style="{DynamicResource GlobalActionButtonStyle}"
                            Content="{DynamicResource Content_MWButton1}"
                            BorderThickness="1,1,1,0"
                            Grid.Column="1" Click="Offline_Click" IsEnabled="False"/>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnLoadFeatures"
                            Style="{DynamicResource GlobalActionButtonStyle}"
                            Content="{DynamicResource Content_MWButton2}"
                            BorderThickness="1,1,0,1"
                            Click="LoadFeatures_Click" IsEnabled="False"/>

                    <Button x:Name="btnLoadPackages"
                            Style="{DynamicResource GlobalActionButtonStyle}"
                            Content="{DynamicResource Content_MWButton3}"
                            BorderThickness="1,1,0,1"
                            Grid.Column="1" Click="LoadPackages_Click"/>

                    <Button x:Name="btnLoadAppx"
                            Style="{DynamicResource GlobalActionButtonStyle}"
                            Content="{DynamicResource Content_MWButton4}"
                            Grid.Column="2" Click="LoadAppx_Click"/>
                </Grid>
            </Grid>
        </Border>

        <ContentControl x:Name="MainContentControl" Grid.Row="1"/>
    </Grid>
</UserControl>
