<UserControl x:Class="WindowsCostumizeWizard.MW_Element.UC_FPA_Element.UC_Features"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:WindowsCostumizeWizard.MW_Element.UC_FPA_Element"
            mc:Ignorable="d">

    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Border Name="LoaderFPA" Padding="5" 
            Background="{DynamicResource GlobalBorderBackground0}" Grid.Row="2"
            BorderBrush="{DynamicResource GlobalBorderBrush0}"
            BorderThickness="1"
            Height="Auto">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Name="AllStatusFeatures" Background="{DynamicResource GlobalBorderBackground1}"
                    BorderBrush="{DynamicResource GlobalBorderBrush0}"
                    Padding="5" BorderThickness="1" Height="Auto">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Name="STATUSALL" HorizontalAlignment="Left"
                                Orientation="Horizontal">

                        <TextBlock FontSize="10"
                                   Text="{DynamicResource Text_FeaturesEnabled}"
                                   Foreground="{DynamicResource GlobalTitleForeground1}"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:Name="EnabledFeatures"
                                   Text="{Binding NumberEnabled}" Margin="5,0" FontSize="10"
                                   Foreground="{DynamicResource GlobalTitleForeground1}"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"/>

                        <TextBlock FontSize="10"
                                   Text="{DynamicResource Text_FeaturesDisabled}"
                                   Foreground="{DynamicResource GlobalTitleForeground1}"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:Name="DisabledFeatures"
                                   Text="{Binding NumberDisabled}" Margin="5,0"
                                   Foreground="{DynamicResource GlobalTitleForeground1}"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"/>

                        <TextBlock FontSize="10"
                                   Text="{DynamicResource Text_FeaturesOther }"
                                   Foreground="{DynamicResource GlobalTitleForeground1}"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:Name="OtherFeatures"
                                   Text="{Binding NumberOther}" Margin="5,0" FontSize="10"
                                   Foreground="{DynamicResource GlobalTitleForeground1}"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Grid.Column="2">

                        <TextBlock FontSize="10"
                                   Text="{DynamicResource Text_FeaturesAll}" Margin="5,0"
                                   Foreground="{DynamicResource GlobalTitleForeground1}"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:Name="AllNumber"
                                   Text="{Binding NumberAll}" FontSize="10"
                                   Foreground="{DynamicResource GlobalTitleForeground1}"
                                   Background="Transparent"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Name="ListFeatures" Grid.Row="1" Margin="0,5,0,0"
                    Background="{DynamicResource MainBorderGradient}"
                    BorderBrush="{DynamicResource GlobalBorderBrush0}"
                    BorderThickness="1" Height="244" Width="Auto">

                <TreeView ItemsSource="{Binding FeaturesList}"
                          Background="Transparent" Padding="0,2">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                                                                                
                                <TextBlock Text="{Binding State}" Margin="5,0"
                                           Foreground="{Binding Foreground}"
                                           Width="Auto" MinWidth="45"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>

                                <CheckBox IsChecked="{Binding IsChecked}"
                                          IsEnabled="{Binding IsEnabledCheck}"
                                          VerticalAlignment="Center"
                                          Checked="CheckBox_StateChanged"
                                          Unchecked="CheckBox_StateChanged"/>

                                <TextBlock Text="{Binding Name}" Margin="5,0"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource GlobalTitleForeground1}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabledCheck}" Value="False">
                                                    <Setter Property="Foreground" Value="Gray"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                
                                <Button Style="{DynamicResource GlobalActionButtonStyleC}"
                                        Content="Вибрати"
                                        BorderThickness="1" Width="70"
                                        Visibility="{Binding IsPayloadRemoved, Converter={StaticResource BoolToVisibility}}"
                                        Click="OpenNetFx3Source_Click"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <StackPanel Grid.Row="2" Name="Jurnal">
                <Border Background="{DynamicResource GlobalBorderBackground4}"
                        BorderBrush="{DynamicResource GlobalBorderBrush1}"
                        Padding="5" Margin="0,5" BorderThickness="1">

                    <TextBlock x:Name="TextStatusFeaturesPC"
                               Text="{Binding StatusFeaturesPC}"
                               Foreground="IndianRed"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                
                <CheckBox x:Name="cbConsoleView" Content="Виводити консоль"
                             Foreground="{DynamicResource GlobalTitleForeground2}"
                             FontStyle="Italic"/>

                <Border BorderBrush="{DynamicResource GlobalBorderBrush0}"
                        Background="{DynamicResource GlobalBorderBackground3}"
                        BorderThickness="1"
                        Margin="0,5" Height="170">

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanelFeaturesList" Orientation="Vertical"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="UpdateFeatures" Style="{DynamicResource GlobalActionButtonStyle}"
                        Content="{DynamicResource Content_FeaturesButton0}" Click="UpdateFeature_Click"/>

                <Button x:Name="OnFeatures" Style="{DynamicResource GlobalActionButtonStyle}"
                        Content="{DynamicResource Content_FeaturesButton2}"
                        Grid.Column="1" Margin="5,0" IsEnabled="False" Click="EnableFeatures_Click"/>

                <Button x:Name="OffFeatures" Style="{DynamicResource GlobalActionButtonStyle}"
                        Content="{DynamicResource Content_FeaturesButton1}"
                        Grid.Column="2" IsEnabled="False" Click="DisableFeatures_Click"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
