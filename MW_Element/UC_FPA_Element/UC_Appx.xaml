<UserControl x:Class="WindowsCostumizeWizard.MW_Element.UC_FPA_Element.UC_Appx"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsCostumizeWizard.MW_Element.UC_FPA_Element"
        mc:Ignorable="d">

    <Border Name="LoaderFPA" Padding="5" 
            Background="{DynamicResource GlobalBorderBackground0}" Grid.Row="2"
            BorderBrush="{DynamicResource GlobalBorderBrush0}"
            BorderThickness="1"
            Height="Auto">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Name="AllStatusAppx" Background="{DynamicResource GlobalBorderBackground1}"
                    BorderBrush="{DynamicResource GlobalBorderBrush0}"
                    Padding="5" BorderThickness="1" Height="Auto">

                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock FontSize="10"
                               Text="{DynamicResource Text_TextAll}"
                               Foreground="{DynamicResource GlobalTitleForeground1}"
                               FontStyle="Italic"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="AllAppx"
                               Text="{Binding NumberAll}" Margin="5,0" FontSize="10"
                               Foreground="{DynamicResource GlobalTitleForeground1}"
                               FontStyle="Italic" Grid.Column="1"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="SelectAll" Content="{DynamicResource Content_SelectAll}"
                          Foreground="{DynamicResource GlobalTitleForeground1}"
                          FontStyle="Italic"
                          Checked="SelectAll_Checked"
                          Unchecked="SelectAll_Checked"/>

                <CheckBox x:Name="ResizeCheckBox" Content="{DynamicResource Content_ShowName}"
                          Foreground="{DynamicResource GlobalTitleForeground1}"
                          FontStyle="Italic" Grid.Column="1"/>
            </Grid>

            <Border Name="ListAppx" Grid.Row="2"
                    Background="{DynamicResource MainBorderGradient}"
                    BorderBrush="{DynamicResource GlobalBorderBrush0}"
                    BorderThickness="1" Height="248" Width="Auto">

                <Grid>
                    <ListView x:Name="AppxListView" SelectionMode="Single"
                              BorderThickness="0" Background="Transparent"
                              ItemsSource="{Binding Packages}">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <!-- Виділення при кліку по рядку або активному чекбоксі -->
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Background" Value="#FF3A3A3A"/>
                                    </DataTrigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF2D2D30"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <!-- нумерація -->
                                    <TextBlock Text="{Binding Number}" Width="20" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource GlobalTitleForeground0}"/>

                                    <!-- чекбокс -->
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Click="CheckBox_Click"/>

                                    <!-- Identity -->
                                    <Border x:Name="BorderName">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Width" Value="295"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Style.Triggers>
                                                    <!-- Чекбокс керує шириною -->
                                                    <DataTrigger Binding="{Binding IsChecked, ElementName=ResizeCheckBox}" Value="True">
                                                        <Setter Property="Width" Value="650"/>
                                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock Text="{Binding PackageName}" Margin="5,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding PackageName}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource GlobalTitleForeground1}"/>
                                                    <Style.Triggers>
                                                        <!-- Зміна кольору при виділенні -->
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource GlobalTitleForeground2}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Architecture -->
                                    <Border Background="Transparent" BorderBrush="{DynamicResource GlobalBorderBrush0}" BorderThickness="1,0" Padding="5,0">
                                        <TextBlock Text="{Binding Architecture}" Width="45">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource GlobalTitleForeground3}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource GlobalTitleForeground2}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Version -->
                                    <TextBlock Text="{Binding Version}" Width="90" Margin="5,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="Orange"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource GlobalTitleForeground2}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Пошук" Foreground="{DynamicResource GlobalTitleForeground1}"
                           FontStyle="Italic" Margin="0,0,5,0"/>

                <TextBox Grid.Column="1"
                         x:Name="SearchBoxAppx"
                         TextChanged="SearchBoxAppx_TextChanged"
                         PreviewTextInput="SearchBoxAppx_PreviewTextInput"/>
            </Grid>

            <CheckBox x:Name="cbConsoleView" Content="Виводити консоль"
                      Foreground="{DynamicResource GlobalTitleForeground2}"
                      FontStyle="Italic" Grid.Row="4"/>

            <Border BorderBrush="{DynamicResource GlobalBorderBrush0}"
                    Background="{DynamicResource GlobalBorderBackground3}"
                    BorderThickness="1" Grid.Row="5"
                    Margin="0,5" Height="159">

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PanelPackagesList" Orientation="Vertical"/>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="UpdateAppx" Style="{DynamicResource GlobalActionButtonStyle}"
                        Content="{DynamicResource Content_PA_Button0}" Click="UpdatePackages_Click"/>

                <Button x:Name="btnRemoveAppx" Style="{DynamicResource GlobalActionButtonStyle}"
                        Content="{DynamicResource Content_PA_Button1}"
                        Grid.Column="1" Margin="5,0,0,0" IsEnabled="False"
                        Click="RemoveAppx_Click"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
