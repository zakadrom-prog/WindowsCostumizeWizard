<Window x:Class="WindowsCostumizeWizard.MW_Element.W_InfoWimEsd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsCostumizeWizard.MW_Element"
        mc:Ignorable="d" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize" ShowInTaskbar="True"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/Images/install.ico">

    <Border Background="{DynamicResource GlobalBorderBackground0}"
            BorderBrush="{DynamicResource GlobalBorderBrush0}"
            BorderThickness="2" Margin="5"
            Padding="5" Width="625"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Grid Name="GridAllView">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Name="TitleOptimize"
                    Background="{DynamicResource GlobalBorderBackground2}"
                    BorderBrush="{DynamicResource GlobalBorderBrush0}" 
                    Padding="3" Width="Auto" Height="Auto"
                    BorderThickness="1">
                
                <Grid Name="GridTitleInstall">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Source="/Resources/Images/install.png" Width="32" Height="32" Margin="5,0,0,0"/>

                    <TextBlock Text="{DynamicResource Text_TitleImageWimInfo}" FontSize="14"
                           Foreground="{DynamicResource GlobalTitleForeground0}"
                           VerticalAlignment="Center" Grid.Column="1"
                           HorizontalAlignment="Center" FontWeight="Bold"/>
                </Grid>
            </Border>

            <Grid Name="GridAB" Grid.Row="1" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Name="PanelInfoA" Margin="0,0,2.5,0">
                    <Border Background="{DynamicResource GlobalBorderBackground4}"
                            BorderBrush="{DynamicResource GlobalBorderBrush1}"
                            Padding="3" BorderThickness="1">
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource Text_TitleImage}"
                                       Foreground="{DynamicResource GlobalTitleForeground3}"
                                       FontStyle="Italic" Margin="0,0,5,0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                            <TextBlock x:Name="TextStatusWim"
                                       Foreground="{DynamicResource GlobalTitleForeground2}"
                                       FontStyle="Italic"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid Name="InfoAllIndex0" Grid.Row="1" Margin="0,5" Height="25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Name="BorderIndex0"
                                Background="{DynamicResource GlobalBorderBackground1}"
                                BorderBrush="{DynamicResource GlobalBorderBrush1}"
                                BorderThickness="1,1,0,1">

                            <TextBlock Text="{DynamicResource Text_Index}"
                                       Foreground="{DynamicResource GlobalTitleForeground1}"
                                       FontStyle="Italic" FontWeight="Medium" Padding="5,0"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <ComboBox x:Name="ComboIndex" Grid.Column="1" FontFamily="Tahoma"
                                  FontStyle="Normal" Background="Black" VerticalAlignment="Center">
                        </ComboBox>
                    </Grid>

                    <Border BorderBrush="{DynamicResource GlobalBorderBrush0}"
                            Background="{DynamicResource GlobalBorderBackground3}"
                            BorderThickness="1" Height="317" Padding="5">

                        <TextBox x:Name="ViewerA"
                                 Background="Transparent"
                                 Foreground="{DynamicResource GlobalTitleForeground3}"
                                 BorderThickness="0"
                                 FontFamily="Tahoma"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 IsReadOnly="True"/>
                    </Border>
                </StackPanel>

                <StackPanel Name="PanelInfoB" Grid.Column="1" Margin="2.5,0,0,0">
                    <Border Background="{DynamicResource GlobalBorderBackground4}"
                            BorderBrush="{DynamicResource GlobalBorderBrush1}"
                            Padding="3" BorderThickness="1">
                        
                        <TextBlock Text="{DynamicResource Text_InfoDetail}"
                                   Foreground="{DynamicResource GlobalTitleForeground2}"
                                   FontStyle="Italic" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <Grid Name="GridButton" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Style="{DynamicResource GlobalActionButtonStyle}"
                                Content="{DynamicResource Content_InfoWimDetail}"
                                Width="Auto" Margin="0,0,2.5,0" 
                                Click="LoadSelectIndexInfo_Click"/>

                        <Button Style="{DynamicResource GlobalActionButtonStyle}"
                                Content="{DynamicResource Content_CleanListIndex}"
                                Grid.Column="1" Width="Auto" Margin="2.5,0,0,0"
                                Click="CleanList_Click"/>
                    </Grid>

                    <Border BorderBrush="{DynamicResource GlobalBorderBrush0}"
                            Background="{DynamicResource GlobalBorderBackground3}"
                            BorderThickness="1" Height="317">

                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ViewerB"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Grid>

            <Button Style="{DynamicResource GlobalActionButtonStyle}"
                    Content="{DynamicResource Content_CloseWindow}"
                    Width="Auto" Grid.Row="3" Click="WindowClose_Click"/>
        </Grid>
    </Border>
</Window>
