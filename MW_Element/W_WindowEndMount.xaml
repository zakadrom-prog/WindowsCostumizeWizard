<Window x:Class="WindowsCostumizeWizard.MW_Element.W_WindowEndMount"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsCostumizeWizard.MW_Element"
        mc:Ignorable="d" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize" ShowInTaskbar="True"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner"
        Icon="Resources/cmd.ico">

    <Border Background="{DynamicResource WI_BorderBackground}"
            BorderBrush="{DynamicResource WI_BorderBrush}"
            BorderThickness="1" Padding="10"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Image Source="/Resources/Images/info.png"
                   Width="40"/>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>


                <TextBlock Text="{DynamicResource Text_EndInfo0}"
                           Foreground="{DynamicResource GlobalTitleForeground1}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" FontWeight="Bold"
                           Margin="0,5"/>

                <TextBlock Text="{DynamicResource Text_EndInfo1}"
                           Foreground="{DynamicResource GlobalTitleForeground3}"
                           VerticalAlignment="Center" Grid.Row="1" FontSize="16"
                           HorizontalAlignment="Center" FontWeight="Bold"/>

                <TextBox Text="{Binding InfoEndMount}"
                         Foreground="{DynamicResource GlobalTitleForeground1}"
                         VerticalAlignment="Center" Grid.Row="2"
                         HorizontalAlignment="Center" FontWeight="Bold"
                         Margin="0,10" TextWrapping="Wrap"
                         Background="Transparent" 
                         IsReadOnly="True" BorderThickness="0"/>
            </Grid>

            <Button Style="{DynamicResource GlobalActionButtonStyle}"
                    Content="{DynamicResource Content_EndCloseInfo}"
                    Width="Auto" Margin="0,0,5,0" Grid.Row="2"
                    Click="CloseWindowInfo_Click"/>

        </Grid>
    </Border>
</Window>
