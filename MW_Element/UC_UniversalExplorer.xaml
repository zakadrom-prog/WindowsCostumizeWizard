<UserControl x:Class="WindowsCostumizeWizard.MW_Element.UC_UniversalExplorer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{DynamicResource ExplorerBackgroundBrush}"
            BorderBrush="{DynamicResource ExplorerBorderBrush}"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 🔍 Пошук -->
            <TextBox x:Name="SearchBox"
                     Height="20"
                     FontStyle="Italic"
                     FontWeight="Bold"
                     Background="LightGray"
                     Foreground="Black"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchBox_TextChanged"
                     ToolTip="Search (English only)"/>

            <!-- 📁 Список -->
            <ListView x:Name="List"
                      Grid.Row="1"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding Icon}"
                                   Width="14"
                                   Height="14"
                                   Margin="0,0,5,0"/>

                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource GlobalTitleForeground1}"
                                       FontStyle="Italic"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</UserControl>