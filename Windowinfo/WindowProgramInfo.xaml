<Window x:Class="WindowsCostumizeWizard.Windowinfo.WindowProgramInfo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/info.ico">

    <Border Background="{DynamicResource WI_BorderBackground}"
            BorderBrush="{DynamicResource WI_BorderBrush}"
            BorderThickness="1" Padding="10"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{DynamicResource Text_TitleInfoWindowInfo}"
                       Foreground="{DynamicResource GlobalTitleForeground0}"
                       FontSize="16" 
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center" FontWeight="Bold"/>

            <TextBlock Text="{Binding InfoText}"
                       Foreground="{DynamicResource GlobalTitleForeground1}"
                       VerticalAlignment="Center" Grid.Row="1" Margin="0,10"
                       HorizontalAlignment="Center" FontWeight="Bold" FontStyle="Italic"/>

            <Button Style="{DynamicResource GlobalActionButtonStyle}"
                    Content="OK" Grid.Column="1"
                    Width="Auto" Click="CloseWindowInfo_Click" Grid.Row="2"/>
        </Grid>
    </Border>
</Window>
