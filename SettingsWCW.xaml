<Window x:Class="WindowsCostumizeWizard.SettingsWCW"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsCostumizeWizard"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Title="{DynamicResource SettingsTitle}"
        Icon="pack://application:,,,/Resources/Images/settings.ico">

    <Grid Background="{DynamicResource GlobalBorderBackground0}">
        <Border Name="BorderSatting" Padding="5" Margin="5"
                Background="{DynamicResource GlobalBorderBackground0}"
                BorderBrush="{DynamicResource GlobalBorderBrush0}"
                BorderThickness="1">

            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{DynamicResource Settings0}"
                               Foreground="{DynamicResource GlobalTitleForeground1}"
                               FontStyle="Italic"
                               Margin="0,0,5,0"
                               VerticalAlignment="Center"/>

                    <ComboBox x:Name="LanguageComboBox" FontStyle="Italic" VerticalAlignment="Center" Width="100"
                              SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBoxItem Content="{DynamicResource SettingsLanguageUA}"/>
                        <ComboBoxItem Content="{DynamicResource SettingsLanguageEN}"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,5,0,0" HorizontalAlignment="Right">
                    <TextBlock Text="{DynamicResource Settings1}"
                           Foreground="{DynamicResource GlobalTitleForeground1}"
                           FontStyle="Italic"
                           Margin="0,0,5,0"
                           VerticalAlignment="Center"/>

                    <ComboBox x:Name="ThemeComboBox" FontStyle="Italic" VerticalAlignment="Center" Width="100"
                              SelectionChanged="ThemeComboBox_SelectionChanged">
                        <ComboBoxItem Content="{DynamicResource SettingsThemesDark}"/>
                        <ComboBoxItem Content="{DynamicResource SettingsThemeslight}"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
