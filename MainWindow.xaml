<Window x:Class="WindowsCostumizeWizard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsCostumizeWizard.MW_Element"
        xmlns:local0="clr-namespace:WindowsCostumizeWizard.MW_Element.UC_FPA_Element"
        xmlns:local1="clr-namespace:WindowsCostumizeWizard.MW_Element.UC_Advansed"
        mc:Ignorable="d" WindowStyle="None"
        RenderTransformOrigin="0.5,0.5"
        Icon="Resources/app.ico" 
        AllowsTransparency="True" ResizeMode="CanResize" 
        Background="Transparent">

    <Window.RenderTransform>
        <ScaleTransform x:Name="WindowScale" ScaleX="1" ScaleY="1"/>
    </Window.RenderTransform>

    <Border BorderBrush="{DynamicResource GlobalBorderBrush0}"
            BorderThickness="1" Margin="6">

        <Grid Name="GridGlobalMW" Background="{DynamicResource GridGlobalMWBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Name="TitleMW" Padding="5"
                    Background="{DynamicResource GlobalBorderBackground2}"
                    BorderBrush="{DynamicResource GlobalBorderBrush0}"
                    Width="Auto" Height="Auto" BorderThickness="1"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Source="{DynamicResource AppIcon}" Width="16"/>

                    <TextBlock Text="{DynamicResource AppTitle}"
                               Foreground="{DynamicResource GlobalTitleForeground0}"
                               Margin="5,0" Grid.Column="1"
                               VerticalAlignment="Center"
                               FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal" Grid.Column="2">
                        <Button Style="{DynamicResource GlobalActionButtonStyleC}"
                                Content="─"
                                BorderThickness="1"
                                Click="Minimize_Click"/>

                        <Button Style="{DynamicResource GlobalActionButtonStyleC}"
                                Content="❐"
                                BorderThickness="1" Margin="5,0"
                                Click="Maximize_Click"/>

                        <Button Style="{DynamicResource GlobalActionButtonStyleC}"
                                Content="❌" FontSize="8"
                                BorderThickness="1"
                                Click="Close_Click"/>
                    </StackPanel>

                </Grid>
            </Border>

            <Border Name="BorderSatting" Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnWcwFolder"
                            Style="{DynamicResource GlobalActionButtonStyle}"
                            Content="{DynamicResource Content_FProg}"
                            BorderThickness="1,0,0,0"
                            Click="WorkDirectory_Click"/>

                    <Button Style="{DynamicResource GlobalActionButtonStyle}"
                            Content="{DynamicResource Content_Sett}" 
                            BorderThickness="1,0,0,0" Grid.Column="1"
                            Click="SettingsProgram_Click"/>

                    <Button Style="{DynamicResource GlobalActionButtonStyle}"
                            Content="{DynamicResource Content_Help}" 
                            BorderThickness="1,0,1,0" Grid.Column="2"
                            Click="HelpInfo_Click"/>

                    <Button Style="{DynamicResource GlobalActionButtonStyle}"
                            Content="{DynamicResource Content_About}"
                            BorderThickness="1,0,0,0" Grid.Column="3"
                            Click="AboutInfo_Click"/>
                </Grid>
            </Border>

            <Border BorderBrush="{DynamicResource GlobalBorderBrush0}"
                    BorderThickness="1" Grid.Row="2" Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <local:UC_ISO x:Name="uc_iso"/>
                        <local:UC_DeleteIndex x:Name="uc_di" Grid.Row="1"/>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <local:UC_WIM x:Name="uc_wim"/>
                        <local1:UC_Advansed x:Name="uc_adv" Grid.Row="1"/>
                    </Grid>

                    <local0:UC_All_FPA x:Name="uc_AllFPA" Grid.Column="2"/>
                </Grid>
            </Border>

            <Border Height="Auto" Width="Auto"
                    Background="#FF171D1D" Grid.Row="3">

                <TextBlock Text="WindowsCostumizeWizard"
                           FontStyle="Italic"
                           Margin="15"
                           HorizontalAlignment="Center"
                           FontSize="20">
                    <TextBlock.Foreground>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF07335D"/>
                            <GradientStop Color="#FF07686F" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</Window>
